            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventType\": \"SENSOR_READING\",\n  \"eventId\": \"123e4567-e89b-12d3-a456-426614174000\",\n  \"deviceId\": \"sensor-01\",\n  \"metric\": \"temperature\",\n  \"value\": 70,\n  \"unit\": \"C\",\n  \"timestamp\": \"2026-05-24T20:00:00Z\"\n}",
              "options": {
